# QQ 官方机器人凭证
QQBOT_APP_ID=1903821930
QQBOT_APP_SECRET=REPLACE_ME
QQBOT_SANDBOX=false
QQBOT_REMOVE_AT=true
QQBOT_INTENTS=GROUP_AT_MESSAGE_CREATE,C2C_MESSAGE_CREATE
QQBOT_LOG_LEVEL=info
QQBOT_MAX_RETRY=10

# 通道策略
PRIVATE_ENABLED=true
ALLOW_GROUP=true
TRIGGER_PREFIX=
PRIVATE_WHITELIST=
GROUP_WHITELIST=

# 回复与思考转发
MAX_REPLY_CHARS=900
SHOW_THOUGHTS=true
THOUGHT_PREFIX=

# 会话管理
IDLE_TIMEOUT_MS=86400000
MAX_CONCURRENT_SESSIONS=20
PROMPT_TIMEOUT_MS=600000
MAX_PROMPT_TIMEOUT_MS=120000
SESSION_STATE_PATH=/home/pi/qqbot-ai-bridge/session-state.json

# 模型后端：
# codex      -> ACP + codex-acp
# claude     -> ACP + claude-agent-acp（等价 claude-acp）
# claude-acp -> ACP + claude-agent-acp
# claude-cli -> Claude CLI stream-json（兜底模式）
MODEL_PROVIDER=codex

# ACP Agent
AGENT_COMMAND=npx
AGENT_ARGS=-y @zed-industries/codex-acp
AGENT_CWD=/home/pi

# Claude CLI（MODEL_PROVIDER=claude-cli 时生效）
CLAUDE_COMMAND=/usr/local/nodejs/bin/claude
CLAUDE_ARGS=
CLAUDE_MODEL=opus

# Claude ACP（MODEL_PROVIDER=claude/claude-acp 时生效）
CLAUDE_ACP_COMMAND=/usr/local/nodejs/bin/claude-agent-acp
CLAUDE_ACP_ARGS=

# GLM via Claude SDK / Claude Code
ANTHROPIC_AUTH_TOKEN=REPLACE_ME
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
API_TIMEOUT_MS=3000000
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
ANTHROPIC_MODEL=glm-5.1
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.1
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5.1
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.5-air
